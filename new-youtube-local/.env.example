# otona_no_psychology 夜19:00枠 ローカル環境変数テンプレ
# 使い方: このファイルを .env にコピーして値を埋める

# === Gemini ===
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# === YouTube Data API (A案 NEW_YOUTUBE 流用) ===
NEW_YOUTUBE_CLIENT_ID=
NEW_YOUTUBE_CLIENT_SECRET=
NEW_YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CATEGORY_ID=22
YOUTUBE_PRIVACY=public

# === VOICEVOX ===
VOICEVOX_URL=http://localhost:50021
VOICEVOX_SPEAKER_NAME=冥鳴ひまり
VOICEVOX_STYLE_NAME=ノーマル
# 直接 style_id を指定したい場合はここに入れる（空なら /speakers から自動解決）
VOICEVOX_STYLE_ID=
VOICEVOX_SPEED=1.0
VOICEVOX_PITCH=0.0
VOICEVOX_INTONATION=1.0

# === Pollinations ===
POLLINATIONS_MODEL=flux
IMG_WIDTH=1280
IMG_HEIGHT=720
IMG_PER_CHAPTER=2

# === 動画 ===
VIDEO_FPS=24
VIDEO_W=1280
VIDEO_H=720
CROSSFADE_SEC=0.8

# === 台本（10分動画用 デフォルト） ===
CHAPTER_CHAR_MIN=1500
CHAPTER_CHAR_MAX=2000
